# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key: server-only, bypasses RLS. Never expose to the client.
# Used for privileged admin operations (e.g. creating a worker's auth user).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Production URL (e.g. your Vercel deployment). Not yet read anywhere in the
# app code -- magic-link redirects currently derive the origin dynamically
# from window.location.origin / the request URL instead. Kept here for
# future use (metadata, sitemaps, etc.) and so it's documented alongside the
# other env vars.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
